{
  "productName": "Big8K",
  "version": "0.1.0",
  "identifier": "com.big8k.control",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Big8K 控制面板",
        "width": 1500,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../Icon/7.ico"
    ],
    "resources": [
      "../resources/*",
      "../fb_operate/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
